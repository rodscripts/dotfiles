#!/bin/sh

# Hide cursor (--null)
if [ "$1" = "--null" ]; then
    tput civis
fi;

# Colors
CBK=$(tput setaf 0)
CRE=$(tput setaf 1)
GRN=$(tput setaf 2)
CYE=$(tput setaf 3)
BLE=$(tput setaf 4)
PNK=$(tput setaf 5)
CCY=$(tput setaf 6)
CWH=$(tput setaf 7)

# Text style
CBD=$(tput bold)
CNC=$(tput sgr0)

# Progress bar
draw() {
  FULL=━
  EMPTY=━
  out=
  perc=$1
  size=$2
  inc=$(( perc * size / 100 ))
  color=34
  color2=31
  for v in $(seq 0 $(( size - 1 ))); do
    [ "$v" -le "$inc" ] && out="${out}${PNK}${FULL}" || out="${out}${CWH}${EMPTY}"
  done
  printf "%b" "$out"
}

# Colorbar
i=1
c=$(printf "\033[0m\033[31m░▒")
while [ "$i" -le 6 ]; do
  c=${c}$(printf "\033[%dm\033[%dm█▓▒░" "$((i+41))" "$((i+30))")
  i=$((i+1))
done
COLORBAR=${c}$(printf "\033[37m█\033[0m▒░")

# Fetch
name=$USER

host=$(uname -n)

distro=$(uname -o | awk -F '"' '/PRETTY_NAME/ { print $2 }' /etc/os-release)

packages=$(pacman -Q | wc -l)

wm=$(echo $GDMSESSION)

storage=$(df -h --output=used / | awk 'NR == 2 { print $1 }')

term=$(ps -o sid= -p "$$" | xargs ps -o ppid= -p | xargs ps -o comm= -p)

uptm=$(uptime -p | sed -e 's/hour/hr/' -e 's/hours/hrs/' -e 's/minutes/mins/' -e 's/minute/min/' -e 's/up //')

protocol=$(echo $XDG_SESSION_TYPE)

c_lvl=$(printf "%.0f" "$(grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {print usage}')")

CPU=$(printf "%-4s\033m%-5s%-25s \n" "${GRN}cpu${CNC} " "$c_lvl%" "$(draw "$c_lvl" 14)")

ram_lvl=$(free | awk '/Mem:/ {print int($3/$2 * 100.0)}')

RAM=$(printf "%-4s\033m%-5s%-25s \n" "${CYE}ram${CNC} " "$ram_lvl%" "$(draw "$ram_lvl" 14)")

disk_lvl=$(df -h | grep '/$' | tr -s ' ' | cut -d ' ' -f5 | sed 's/%//')

DISK=$(printf "%-4s\033m%-5s%-25s \n" "${CCY}disk${CNC} " "$disk_lvl%" "$(draw "$disk_lvl" 14)")

# Clear terminal
clear

# Arch logo
cat <<EOF
$CBD                  
                 $GRN/$BLE\\
                $GRN/  $BLE\\
               $GRN/    $BLE\\
              $GRN/      $BLE\\
             $GRN/   '$BLE'   \\
            $GRN/   |  $BLE|   \\
           $GRN/_-''    $BLE''-_\\
EOF

# Print colorbar
printf "\033[0m\n    %s\033[0m\n\n" "$COLORBAR"

# Print greetings
printf "%s\n" "             $CRE$CBD$name$CNC@$GRN$CBD$host$CNC"
printf "%s\n\n" "           up $CCY$CBD$uptm$CNC"

# Print fetch
printf "%s\n" "$CRE         distro $CWH⏹ $CNC$distro"
printf "%s\n" "$BLE         kernel $CWH⏹ $CNC$(uname -r)"
printf "%s\n" "$CCY    environment $CWH⏹ $CNC${wm} ($CNC${protocol})"
printf "%s\n" "$PNK       packages $CWH⏹ $CNC${packages} (pacman)"
printf "%s\n" "$CYE       terminal $CWH⏹ $CNC${term}"
printf "%s\n" "$GRN          shell $CWH⏹ $CNC${SHELL##*/}"
printf " %s\n" "$CNC"

# Print status
printf "        %s\n        %s\n       %s\033[0m\n" "$CPU" "$RAM" "$DISK"

# Wait for a key and reset terminal
if [ "$1" = "--null" ]; then
    tput civis
    read -n 1 -s -r
    tput cnorm
fi;
